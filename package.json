{
  "name": "voices-headless",
  "version": "3.0.0",
  "description": "Voices Headless Ecosystem",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "cd apps/web && npm run dev",
    "stop": "killall -9 node || true",
    "dev": "cd apps/web && npm run dev",
    "anna": "cd apps/web && npm run lint",
    "build": "cd apps/web && npm run build",
    "check:pre-vercel": "cd apps/web && npm run check:pre-vercel",
    "serve": "cd apps/web && npm run start",
    "lint": "cd apps/web && npm run lint",
    "db:push": "npx drizzle-kit push --config packages/database/drizzle.config.ts --force",
    "db:generate": "npx drizzle-kit generate --config packages/database/drizzle.config.ts",
    "db:migrate": "npx drizzle-kit migrate --config packages/database/drizzle.config.ts",
    "db:studio": "npx drizzle-kit studio --config packages/database/drizzle.config.ts",
    "prepare": "husky || true"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dotenv": "^6.1.1",
    "@types/node": "^25.2.1",
    "@types/nodemailer": "^7.0.9",
    "@vitest/ui": "^4.0.18",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.5.10",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "nodemailer": "^8.0.1",
    "playwright": "^1.58.2",
    "prettier": "^3.6.2",
    "puppeteer": "^24.37.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.95.3",
    "@types/sharp": "^0.31.1",
    "dotenv": "^17.2.4",
    "drizzle-orm": "^0.45.1",
    "gray-matter": "^4.0.3",
    "pg": "^8.18.0",
    "postgres": "^3.4.8",
    "react-image-crop": "^11.0.10",
    "sharp": "^0.34.5"
  },
  "overrides": {
    "react": "^18",
    "react-dom": "^18"
  }
}

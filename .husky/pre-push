#!/usr/bin/env sh
set -e

check_main=0

while read -r local_ref local_sha remote_ref remote_sha
do
  if [ "$remote_ref" = "refs/heads/main" ]; then
    check_main=1
  fi
done

if [ "$check_main" -ne 1 ]; then
  echo "husky(pre-push): non-main push detected, skipping main gate."
  exit 0
fi

echo "husky(pre-push): main push detected, running release gate..."
bash scripts/main-release-gate.sh

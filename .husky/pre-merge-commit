#!/usr/bin/env sh
set -e

current_branch="$(git rev-parse --abbrev-ref HEAD)"

if [ "$current_branch" != "main" ]; then
  echo "husky(pre-merge-commit): branch is '$current_branch', skipping main gate."
  exit 0
fi

echo "husky(pre-merge-commit): merge into main detected, running release gate..."
bash scripts/main-release-gate.sh
